{
  "name": "openmrs",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "main": "dist/index.js",
  "bin": {
    "openmrs": "./dist/cli.js",
    "rspack": "./bin/rspack.js",
    "webpack": "./bin/webpack.js"
  },
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">= 20.0.0"
  },
  "scripts": {
    "start": "node ./dist/cli.js",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "build": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "lint": "eslint src --ext ts,tsx"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-core.git"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-core/issues"
  },
  "keywords": [
    "openmrs",
    "microfrontends",
    "cli",
    "tool"
  ],
  "homepage": "https://github.com/openmrs/openmrs-esm-core#readme",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "@openmrs/esm-app-shell": "workspace:*",
    "@openmrs/rspack-config": "workspace:*",
    "@openmrs/webpack-config": "workspace:*",
    "@pnpm/npm-conf": "^3.0.2",
    "@rspack/cli": "1.7.9",
    "@rspack/core": "1.7.9",
    "@rspack/dev-server": "1.1.5",
    "@swc/core": "1.15.18",
    "autoprefixer": "10.4.20",
    "browserslist-config-openmrs": "^1.0.1",
    "chalk": "^4.1.2",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "5.2.7",
    "ejs": "^3.1.8",
    "glob": "^13.0.5",
    "html-webpack-plugin": "5.5.3",
    "html-webpack-tags-plugin": "3.0.2",
    "lodash": "4.17.21",
    "mini-css-extract-plugin": "2.9.1",
    "node-watch": "^0.7.4",
    "npm-registry-fetch": "^19.0.0",
    "open": "^10.1.1",
    "pacote": "^21.3.1",
    "sass-embedded": "1.89.2",
    "sass-loader": "16.0.5",
    "semver": "^7.7.3",
    "style-loader": "3.3.4",
    "swc-loader": "0.2.7",
    "tar": "^7.5.9",
    "typescript": "5.8.3",
    "webpack": "5.105.3",
    "webpack-bundle-analyzer": "4.10.2",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.3",
    "webpack-stats-plugin": "1.1.3",
    "yargs": "^17.6.2"
  },
  "devDependencies": {
    "@inquirer/testing": "^3.2.0",
    "@swc/cli": "^0.7.7",
    "@types/express": "^4.11.1",
    "@types/lodash": "^4.17.21",
    "@types/node": "^20",
    "@types/pacote": "^11.1.8",
    "@types/react": "^18.3.21",
    "@types/semver": "^7",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
