{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "lib": ["es5", "es2020"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
