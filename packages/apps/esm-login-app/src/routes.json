{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.24.0"
  },
  "pages": [
    {
      "component": "root",
      "route": "login",
      "online": true,
      "offline": true
    },
    {
      "component": "root",
      "route": "logout",
      "online": true,
      "offline": true
    },
    {
      "component": "root",
      "route": "change-password",
      "online": true,
      "offline": true
    }
  ],
  "extensions": [
    {
      "name": "location-picker",
      "slot": "location-picker",
      "component": "locationPicker",
      "online": true,
      "offline": true
    },
    {
      "name": "logout-button",
      "slot": "user-panel-bottom-slot",
      "component": "logoutButton",
      "online": true,
      "offline": true
    },
    {
      "name": "password-changer",
      "slot": "user-panel-slot",
      "component": "changePasswordLink",
      "online": true,
      "offline": true
    },
    {
      "name": "location-changer",
      "slot": "top-nav-info-slot",
      "component": "changeLocationLink",
      "online": true,
      "offline": true,
      "order": 1
    },
    {
      "name": "workspace-test-nav-button",
      "component": "workspaceTestActionButton",
      "order": 1
    },
    {
      "name": "workspace-test-2-nav-button",
      "component": "workspaceTestActionButton2",
      "order": 2
    }
  ],
  "modals": [
    {
      "name": "change-password-modal",
      "component": "changePasswordModal"
    }
  ],
  "workspaces": [
    {
      "name": "workspace-test",
      "component": "workspaceTest",
      "type": "workspace-test",
      "title": "Workspace Test",
      "canHide": true
    },
    {
      "name": "workspace-test-2",
      "component": "workspaceTest",
      "type": "workspace-test-2",
      "title": "Workspace Test 2",
      "canHide": true
    }
  ],
  "workspaceGroups2": [
    {
      "groupName": "workspace-group-test",
      "windows": [
        {
          "windowName": "window1",
          "icon": "workspace-test-nav-button",
          "canHide": true,
          "canMaximize": true,
          "overlay": false,
          "workspaces": [
            "workspace-test"
          ]
        },
        {
          "windowName": "window2",
          "icon": "workspace-test-2-nav-button",
          "canHide": true,
          "canMaximize": true,
          "overlay": false,
          "workspaces": [
            "workspace-test-2"
          ]
        }
      ]
    }
  ]
}
